{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@ui": [
        "./src/components/ui/index.ts"
      ],
      "@ui/*": [
        "./src/components/ui/*"
      ],
      "@layout": [
        "./src/components/layout/index.ts"
      ],
      "@layout/*": [
        "./src/components/layout/*"
      ],
      "@sections": [
        "./src/components/sections/index.ts"
      ],
      "@sections/*": [
        "./src/components/sections/*"
      ],
      "@shared": [
        "./src/components/shared/index.ts"
      ],
      "@shared/*": [
        "./src/components/shared/*"
      ],
      "@effects": [
        "./src/components/effects/index.ts"
      ],
      "@effects/*": [
        "./src/components/effects/*"
      ],
      "@admin": [
        "./src/components/admin/index.ts"
      ],
      "@admin/*": [
        "./src/components/admin/*"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@contexts/*": [
        "./src/contexts/*"
      ],
      "@assets/*": [
        "./src/assets/*"
      ],
      "@styles/*": [
        "./src/styles/*"
      ],
      "@lib/*": [
        "./src/lib/*"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "vite-components"
  ]
}
